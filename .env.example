# Copy this file to .env for local manager-only configuration.
# Never commit the copied .env file or place this key in browser code.
LLM_API_KEY=

# Optional endpoint/model overrides. The defaults use the internal NVIDIA
# Inference Hub deployment configured by the manager.
# NVIDIA_CAPTION_ENDPOINT=https://inference-api.nvidia.com/v1/chat/completions
# NVIDIA_CAPTION_MODEL=nvidia/nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
